# Environment Variables for Skill-Bridge Career Navigator

# Gemini AI Configuration (Required for AI features)
# Get your free API key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Configuration
FRONTEND_URL=http://localhost:3000

# Development Settings
DEBUG=true
LOG_LEVEL=info

# Alternative AI Providers (Examples for future use)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# Database Configuration (if switching from JSON to DB in future)
# DATABASE_URL=postgresql://user:pass@localhost/skillbridge
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=skillbridge
# DATABASE_USER=skillbridge_user
# DATABASE_PASSWORD=your_password

# Monitoring & Analytics (Optional)
# ANALYTICS_ENABLED=false
# SENTRY_DSN=your_sentry_dsn_here

# Rate Limiting
# MAX_REQUESTS_PER_MINUTE=60