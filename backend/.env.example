# Environment Configuration for Skill-Bridge Career Navigator Backend

# Gemini AI Configuration (Optional - system has fallback)
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Server Configuration
HOST=127.0.0.1
PORT=8000

# Environment
ENVIRONMENT=development

# CORS Configuration (for frontend integration)
CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001", "http://127.0.0.1:3000", "http://127.0.0.1:3001"]

# Logging Level
LOG_LEVEL=INFO

# Security Settings (Development Only)
# Note: SSL verification is disabled for development environment
# Do NOT use these settings in production
DISABLE_SSL_VERIFICATION=true